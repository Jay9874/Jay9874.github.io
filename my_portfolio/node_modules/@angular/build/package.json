{
  "name": "@angular/build",
  "version": "22.0.6",
  "description": "Official build system for Angular",
  "keywords": [
    "Angular CLI",
    "Angular DevKit",
    "angular",
    "angular-cli",
    "devkit",
    "sdk"
  ],
  "exports": {
